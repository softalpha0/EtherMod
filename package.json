{
  "name": "ethermod",
  "version": "1.1.0",
  "description": "EtherMod — automated Web3 JS/TS migration toolkit covering ethers.js, wagmi, and @solana/web3.js",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "publish:all": "npm run publish --workspaces"
  },
  "keywords": ["codemod", "web3", "migration", "ethers", "wagmi", "solana"],
  "license": "MIT"
}
